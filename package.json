{
  "name": "messages",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@8.6.7",
  "scripts": {
    "build": "svelte-kit sync && vite build",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "dev": "vite dev --host 0.0.0.0 --port 3000",
    "start": "vite dev --host 0.0.0.0 --port 3000",
    "server": "vite dev --host 0.0.0.0 --port 3000",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "tui": "tsx src/client/index.ts",
    "client": "tsx src/client/index.ts",
    "db:seed": "tsx src/scripts/db.ts seed",
    "db:reset": "tsx src/scripts/db.ts reset",
    "test": "vitest run",
    "lint": "biome check src",
    "fix": "biome check --write --unsafe src && UPDATE_SCHEMA=true vitest run src/server/schema.test.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "blessed": "^0.1.81",
    "svelte": "^5.53.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/blessed": "^0.1.25",
    "@types/node": "^22.13.10",
    "svelte-check": "^4.3.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^7.1.12",
    "vitest": "^4.1.0"
  }
}
